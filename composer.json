{
    "name": "spdotdev/splotnikov-dev",
    "description": "splotnikov.dev portfolio site, packaged for the sd-admin host app.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Spdotdev\\SplotnikovDev\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Spdotdev\\SplotnikovDev\\SplotnikovDevServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
