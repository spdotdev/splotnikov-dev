# Environment variables consumed by spdotdev/splotnikov-dev.
#
# This package is a Laravel library, not a standalone app — it has no .env
# of its own. Copy the lines below into the *host application's* .env so the
# package works as soon as it's installed. Every variable already has a safe
# default (see config/splotnikov-dev.php), so omitting this file entirely
# will NOT break the install; it only lets you override the defaults.

# Host this package answers on. Defaults to "splotnikov.dev" if unset.
# Set this to a local/staging host (e.g. localhost) when verifying the
# package outside of production.
SPLOTNIKOV_DOMAIN=splotnikov.dev
